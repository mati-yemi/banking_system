# Flask Configuration
FLASK_ENV=development
FLASK_APP=banking_system/run.py
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Security
SECRET_KEY=dev-secret-key-change-in-production
REMEMBER_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False
WTF_CSRF_SSL_STRICT=False

# Database (Local Development - SQLite)
# For PythonAnywhere, change to: mysql://username:password@username.mysql.pythonanywhere.com/username$databasename
DATABASE_URL=sqlite:///instance/neobank.db

# Audit Logging
AUDIT_LOG_FILE=logs/audit.log

# Rate Limiting Storage (development only uses memory)
RATELIMIT_STORAGE_URL=memory://
